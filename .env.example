VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Auto.dev Plate-to-VIN — 1,000 free lookups/month
# Sign up at https://www.auto.dev
VITE_AUTO_DEV_API_KEY=

# Error Tracking (Sentry)
# Get from: https://sentry.io/settings/projects/your-project/keys/
# Optional - leave empty to disable error tracking
VITE_SENTRY_DSN=

# Push Notifications (Web Push VAPID Keys - Public key only for frontend)
# Generate keys with: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# ============================================
# EDGE FUNCTION SECRETS (Server-Side Only)
# ============================================
# These MUST be set in Supabase Dashboard -> Edge Functions -> Secrets
# NEVER add these to .env with VITE_ prefix (that exposes them to browsers)

# Required for AI Content Moderation (moderate-content function)
# Get from: https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...your-anthropic-key...

# Required for Document Verification (verify-document function)
# Get from: https://platform.openai.com
# OPENAI_API_KEY=sk-...your-openai-key...

# Required for License Plate Hashing (hash-plate function)
# Generate a random 32+ character string
# PLATE_PEPPER=your-random-32-char-secret-here

# Required for Push Notifications (send-push-notification function)
# VAPID_PRIVATE_KEY=your-vapid-private-key
# VAPID_EMAIL=mailto:admin@yourdomain.com
